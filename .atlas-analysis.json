  "keyFeatures": [
    "Cross-platform 2D and 3D game engine",
    "Visual editor with scene system",
    "GDScript scripting language with C# support",
    "Built-in physics engines for 2D and 3D",
    "Advanced animation system with AnimationTree",
    "Comprehensive UI toolkit with Control nodes",
    "Multi-platform export (Desktop, Mobile, Web, Console)",
    "Plugin and extension system (GDExtension)",
    "Visual shader editor",
    "Networking and multiplayer support",
    "Audio engine with effects and spatial audio",
    "Particle systems for 2D and 3D",
    "Navigation and pathfinding (NavMesh)",
    "Tile-based map editor",
    "Asset import pipeline",
    "Live editing and remote debugging"
  ],
  "publicApiSurface": [
    "Node - Base class for all scene objects",
    "Node2D - Base node for 2D objects",
    "Node3D - Base node for 3D objects",
    "Object - Base class for all classes",
    "Resource - Base class for serializable data",
    "SceneTree - Manages the scene hierarchy",
    "Input - Input singleton for handling input events",
    "RenderingServer - Low-level rendering API",
    "PhysicsServer2D - 2D physics server",
    "PhysicsServer3D - 3D physics server",
    "AudioServer - Audio playback and mixing",
    "DisplayServer - Display and window management",
    "NavigationServer2D - 2D pathfinding",
    "NavigationServer3D - 3D pathfinding",
    "EditorPlugin - Base class for editor plugins",
    "GDScript - Built-in scripting language",
    "GDExtension - Native extension system",
    "AnimationPlayer - Animation playback",
    "AnimationTree - Advanced animation blending",
    "Control - Base class for UI elements",
    "Viewport - Render target and camera container",
    "Camera2D - 2D camera",
    "Camera3D - 3D camera",
    "RigidBody2D/3D - Physics-based rigid bodies",
    "CharacterBody2D/3D - Character controllers",
    "Area2D/3D - Detection and overlap areas",
    "CollisionShape2D/3D - Collision shapes",
    "Sprite2D - 2D sprite rendering",
    "MeshInstance3D - 3D mesh rendering",
    "Light2D/Light3D - Lighting",
    "TileMap - Tile-based 2D maps",
    "PackedScene - Serialized scene resource",
    "Engine - Engine configuration singleton",
    "ProjectSettings - Project configuration",
    "OS - Operating system interface"
  ]
}
